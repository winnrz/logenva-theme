{%- comment -%}
  Site-wide banner shown only to customers whose account is pending approval
  (logged in, no 'approved' tag). Sits above the header. Not dismissable.
  Expects `longeva_state` to be assigned by the surrounding layout
  (see layout/theme.liquid).
{%- endcomment -%}

{%- if longeva_state == 'pending' -%}
  <div class="pending-banner" role="status" aria-live="polite">
    <div class="pending-banner__inner page-width">
      <p class="pending-banner__copy">
        <span class="pending-banner__lead">Your practitioner account is awaiting approval.</span>
        <span class="pending-banner__sub">We'll email you once verified, usually within one working day.</span>
      </p>
    </div>
  </div>
{%- endif -%}

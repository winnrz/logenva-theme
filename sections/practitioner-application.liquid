{{ 'section-practitioner-application.css' | asset_url | stylesheet_tag }}
<script src="{{ 'practitioner-application.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .shopify-section-group-header-group,
  .shopify-section-group-footer-group {
    display: none !important;
  }

  body {
    background-color: var(--color-text-secondary);
  }

  #MainContent {
    padding: 0 !important;
    margin: 0 !important;
    max-width: none !important;
  }
{%- endstyle -%}

<div class="practitioner-application">
  <div class="practitioner-application__panel practitioner-application__panel--brand" aria-hidden="true">
    <div class="practitioner-application__wordmark">
      {{ 'longeva-wordmark.svg' | inline_asset_content }}
    </div>
  </div>

  <div class="practitioner-application__panel practitioner-application__panel--form">
    <div class="practitioner-application__form-wrap">
      <header class="practitioner-application__header">
        <h1 class="practitioner-application__title">Practitioner Application</h1>
        <p class="practitioner-application__lead">
          We&rsquo;ll review your credentials and email you once your application has been approved.
        </p>
      </header>

      {%- form 'contact', id: 'practitioner-application-form', enctype: 'multipart/form-data' -%}
        {%- if form.posted_successfully? -%}
          <div class="practitioner-application__success" role="status">
            <h2 class="practitioner-application__success-title">Application received</h2>
            <p>
              Thanks for applying. We&rsquo;ll review your credentials and email you
              once your application has been approved. This usually takes 1&ndash;2
              working days.
            </p>
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="practitioner-application__error" role="alert">
              {%- for field in form.errors -%}
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}.
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          <input type="hidden" name="contact[subject]" value="Practitioner Application">

          <div class="practitioner-application__section">
            <h2 class="practitioner-application__section-title">Account details</h2>

            <div class="practitioner-application__field">
              <label for="ApplicationForm-Name" class="practitioner-application__label">Full name</label>
              <input
                type="text"
                name="contact[name]"
                id="ApplicationForm-Name"
                class="practitioner-application__input"
                value="{% if form.name %}{{ form.name }}{% endif %}"
                autocomplete="name"
                required
              >
            </div>

            <div class="practitioner-application__field">
              <label for="ApplicationForm-Email" class="practitioner-application__label">Email address</label>
              <input
                type="email"
                name="contact[email]"
                id="ApplicationForm-Email"
                class="practitioner-application__input"
                value="{% if form.email %}{{ form.email }}{% endif %}"
                autocomplete="email"
                spellcheck="false"
                autocapitalize="off"
                required
              >
            </div>
          </div>

          <div class="practitioner-application__section">
            <h2 class="practitioner-application__section-title">Professional information</h2>

            <div class="practitioner-application__field">
              <label for="ApplicationForm-Business" class="practitioner-application__label">Business name</label>
              <input
                type="text"
                name="contact[business_name]"
                id="ApplicationForm-Business"
                class="practitioner-application__input"
                autocomplete="organization"
                required
              >
            </div>

            <div class="practitioner-application__field">
              <label for="ApplicationForm-Role" class="practitioner-application__label">Professional role</label>
              <select
                name="contact[professional_role]"
                id="ApplicationForm-Role"
                class="practitioner-application__input practitioner-application__select"
                required
              >
                <option value="" disabled selected>Select your role</option>
                <option value="Nurse">Nurse</option>
                <option value="Doctor">Doctor</option>
                <option value="Aesthetician">Aesthetician</option>
              </select>
            </div>

            <div class="practitioner-application__field">
              <span class="practitioner-application__label">Credentials or proof of qualification</span>
              <div class="practitioner-application__uploader" data-uploader>
                <span class="practitioner-application__uploader-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                    <polyline points="12 11 12 17"></polyline>
                    <polyline points="9 14 12 11 15 14"></polyline>
                  </svg>
                </span>
                <p class="practitioner-application__uploader-prompt">Select your file or drag and drop</p>
                <p class="practitioner-application__uploader-hint">.jpg, .png, .pdf, .doc</p>
                <button type="button" class="practitioner-application__uploader-trigger" data-uploader-trigger>upload</button>
                <p class="practitioner-application__uploader-filename is-hidden" data-uploader-filename></p>
              </div>
              <input
                type="file"
                name="contact[certificate]"
                id="ApplicationForm-Cert"
                class="practitioner-application__file-input"
                data-uploader-input
                accept=".jpg,.jpeg,.png,.pdf,.doc,.docx"
                required
              >
            </div>
          </div>

          <button type="submit" class="practitioner-application__button">Submit application</button>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Practitioner application",
  "settings": []
}
{% endschema %}
